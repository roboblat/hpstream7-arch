#!/usr/bin/env bash
# ============================================================
# HP Stream 7 — Guided Arch Linux Installer
# Targets the internal eMMC (/dev/mmcblk0) by default.
# ============================================================
set -euo pipefail

RED='\033[0;31m'; YEL='\033[1;33m'; GRN='\033[0;32m'; NC='\033[0m'
info()  { echo -e "${GRN}[INFO]${NC}  $*"; }
warn()  { echo -e "${YEL}[WARN]${NC}  $*"; }
die()   { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }

# ── sanity checks ──────────────────────────────────────────────────────────────
[[ $EUID -eq 0 ]] || die "Run as root: sudo hpstream7-install"
[[ -d /sys/firmware/efi ]] || warn "UEFI not detected — bootloader install may fail."

TARGET="/dev/mmcblk0"
[[ -b "$TARGET" ]] || die "$TARGET not found. Is the eMMC present?"

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║   HP Stream 7 — Arch Linux Installer             ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""
warn "This will ERASE ALL DATA on $TARGET"
read -rp "Type 'yes' to continue: " confirm
[[ "$confirm" == "yes" ]] || { info "Aborted."; exit 0; }

# ── gather user preferences ────────────────────────────────────────────────────
read -rp "Hostname [hpstream7]: " HOSTNAME; HOSTNAME="${HOSTNAME:-hpstream7}"
read -rp "Username: " USERNAME
[[ -n "$USERNAME" ]] || die "Username cannot be empty."
read -rsp "Password for $USERNAME: " USERPASS; echo
read -rsp "Root password: " ROOTPASS; echo

read -rp "Filesystem — (1) ext4  (2) f2fs [2]: " FSTYPE_CHOICE
case "${FSTYPE_CHOICE:-2}" in
    1) FSTYPE="ext4" ;;
    2) FSTYPE="f2fs" ;;
    *) die "Invalid choice." ;;
esac

read -rp "Timezone [UTC]: " TIMEZONE; TIMEZONE="${TIMEZONE:-UTC}"
read -rp "Locale [en_US.UTF-8]: " LOCALE; LOCALE="${LOCALE:-en_US.UTF-8}"

# ── partitioning ───────────────────────────────────────────────────────────────
info "Partitioning $TARGET ..."
# Layout:
#   mmcblk0p1  512 MB  EFI System Partition (FAT32)
#   mmcblk0p2  rest    Root partition ($FSTYPE)
sgdisk --zap-all "$TARGET"
sgdisk \
    -n 1:0:+512M  -t 1:ef00 -c 1:"EFI"  \
    -n 2:0:0      -t 2:8300 -c 2:"root" \
    "$TARGET"
partprobe "$TARGET"
sleep 1

ESP="${TARGET}p1"
ROOT="${TARGET}p2"

info "Formatting ESP as FAT32 ..."
mkfs.fat -F32 -n "ESP" "$ESP"

info "Formatting root as $FSTYPE ..."
case "$FSTYPE" in
    ext4) mkfs.ext4 -L root "$ROOT" ;;
    f2fs) mkfs.f2fs -l root -O extra_attr,inode_checksum,sb_checksum "$ROOT" ;;
esac

# ── mounting ───────────────────────────────────────────────────────────────────
info "Mounting filesystems ..."
mount "$ROOT" /mnt
mkdir -p /mnt/boot/efi
mount "$ESP" /mnt/boot/efi

# ── base install ───────────────────────────────────────────────────────────────
info "Updating mirrorlist (reflector) ..."
reflector --latest 10 --protocol https --sort rate \
    --save /etc/pacman.d/mirrorlist 2>/dev/null || true

info "Installing base system (this takes a while) ..."
pacstrap -K /mnt \
    base base-devel linux linux-firmware linux-headers \
    grub efibootmgr \
    networkmanager iwd \
    sudo vim nano git \
    alsa-utils sof-firmware \
    pipewire pipewire-alsa pipewire-pulse wireplumber \
    xf86-video-intel mesa libva-intel-driver \
    xf86-input-libinput \
    xorg-server xorg-xinput xorg-xrandr xorg-xset \
    lxde lxdm lxterminal \
    alacritty zsh zsh-autosuggestions zsh-syntax-highlighting \
    starship neofetch lolcat figlet btop cmatrix \
    ttf-jetbrains-mono-nerd ttf-fira-code \
    papirus-icon-theme arc-gtk-theme feh picom \
    bluez bluez-utils blueman pulseaudio-bluetooth \
    onboard xdotool xinput_calibrator \
    tlp acpid upower \
    iio-sensor-proxy python \
    zram-generator \
    "${FSTYPE}-tools" || true   # f2fs-tools or e2fsprogs

# ── fstab ──────────────────────────────────────────────────────────────────────
info "Generating fstab ..."
genfstab -U /mnt >> /mnt/etc/fstab

# ── copy device config ─────────────────────────────────────────────────────────
info "Copying HP Stream 7 device configuration ..."
cp -a /etc/modprobe.d/hpstream7.conf      /mnt/etc/modprobe.d/
cp -a /etc/udev/rules.d/99-hpstream7*.rules /mnt/etc/udev/rules.d/
cp -a /etc/X11/xorg.conf.d/99-hpstream7.conf /mnt/etc/X11/xorg.conf.d/
cp -a /etc/NetworkManager/conf.d/rtl8723bs.conf /mnt/etc/NetworkManager/conf.d/
cp -a /etc/systemd/zram-generator.conf    /mnt/etc/systemd/
cp -a /etc/systemd/system/rtl8723bs-bluetooth.service /mnt/etc/systemd/system/
cp -a /etc/systemd/system/screen-rotation.service     /mnt/etc/systemd/system/
cp -a /etc/lxdm/lxdm.conf                 /mnt/etc/lxdm/
cp -a /etc/X11/xorg.conf.d/40-touchscreen.conf /mnt/etc/X11/xorg.conf.d/
cp -a /usr/local/bin/hpstream7-*          /mnt/usr/local/bin/
cp -a /usr/local/bin/fix-wifi             /mnt/usr/local/bin/
cp -a /usr/local/bin/fix-touch            /mnt/usr/local/bin/
cp -a /usr/local/bin/fix-bluetooth        /mnt/usr/local/bin/

# vaporwave theme files
cp -a /etc/skel/.                         /mnt/etc/skel/ 2>/dev/null || true
mkdir -p /mnt/usr/share/backgrounds/vaporwave
cp -a /usr/share/backgrounds/vaporwave/.  /mnt/usr/share/backgrounds/vaporwave/ 2>/dev/null || true
# copy Silead firmware if present
[[ -f /usr/lib/firmware/silead/mssl1680.fw ]] && \
    { mkdir -p /mnt/usr/lib/firmware/silead
      cp /usr/lib/firmware/silead/mssl1680.fw /mnt/usr/lib/firmware/silead/; }

# ── chroot configuration ───────────────────────────────────────────────────────
info "Configuring system inside chroot ..."
arch-chroot /mnt /bin/bash -s "$HOSTNAME" "$USERNAME" "$USERPASS" "$ROOTPASS" \
    "$TIMEZONE" "$LOCALE" "$ESP" "$TARGET" << 'CHROOT'
HOSTNAME="$1"; USERNAME="$2"; USERPASS="$3"; ROOTPASS="$4"
TIMEZONE="$5"; LOCALE="$6"; ESP="$7"; TARGET="$8"

# locale & timezone
sed -i "s/^#${LOCALE}/${LOCALE}/" /etc/locale.gen
locale-gen
echo "LANG=${LOCALE}" > /etc/locale.conf
ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime
hwclock --systohc

# hostname
echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts << EOF
127.0.0.1  localhost
::1        localhost
127.0.1.1  ${HOSTNAME}.localdomain ${HOSTNAME}
EOF

# passwords & user
echo "root:${ROOTPASS}" | chpasswd
useradd -m -G wheel,audio,video,input,storage,power -s /bin/zsh "$USERNAME"
echo "${USERNAME}:${USERPASS}" | chpasswd
# copy skeleton theme files into new user's home
cp -a /etc/skel/. "/home/${USERNAME}/" 2>/dev/null || true
chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}"
sed -i 's/^# %wheel ALL=(ALL:ALL) ALL/%wheel ALL=(ALL:ALL) ALL/' /etc/sudoers

# initramfs — add mmc_block and f2fs/goodix to MODULES
sed -i 's/^MODULES=()/MODULES=(mmc_block sdhci_acpi rtsx_pci_sdmmc goodix silead intel_lpss_pci intel_lpss)/' /etc/mkinitcpio.conf
mkinitcpio -P

# GRUB — install BOTH ia32 and x86_64 EFI targets
# The HP Stream 7 firmware is 32-bit EFI even though the CPU is 64-bit.
grub-install --target=i386-efi    --efi-directory=/boot/efi \
             --bootloader-id=GRUB_IA32 --removable
grub-install --target=x86_64-efi  --efi-directory=/boot/efi \
             --bootloader-id=GRUB --removable

# GRUB config tweaks for Bay Trail
cat >> /etc/default/grub << 'EOF'

# HP Stream 7 Bay Trail kernel parameters
GRUB_CMDLINE_LINUX_DEFAULT="quiet loglevel=3 intel_idle.max_cstate=1 \
  i915.fastboot=1 i915.enable_rc6=1 \
  clocksource=tsc tsc=reliable \
  initrd.compress=zstd \
  usbcore.autosuspend=-1"

GRUB_GFXMODE=1280x800x32
GRUB_GFXPAYLOAD_LINUX=keep
EOF
grub-mkconfig -o /boot/grub/grub.cfg

# services
systemctl enable NetworkManager
systemctl enable lxdm
systemctl enable tlp
systemctl enable acpid
systemctl enable fstrim.timer
systemctl enable screen-rotation.service
systemctl enable systemd-zram-setup@zram0.service
systemctl enable rtl8723bs-bluetooth.service
systemctl enable bluetooth.service
# Add the new user to the lp group so blueman/bluez works without sudo
usermod -aG lp "$USERNAME"

CHROOT

# ── done ───────────────────────────────────────────────────────────────────────
info "Unmounting ..."
umount -R /mnt

echo ""
echo -e "${GRN}Installation complete!${NC}"
echo "Remove the USB drive and reboot:"
echo "  systemctl reboot"
